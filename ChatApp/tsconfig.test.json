{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": ".test-build",
    "rootDir": ".",
    "types": ["node"],
    "allowJs": false,
    "noEmit": false
  },
  "include": [
    "src/services/apiClient.ts",
    "src/services/types.ts",
    "src/config/env.ts",
    "src/services/__tests__/**/*.ts"
  ]
}
